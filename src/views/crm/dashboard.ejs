<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - CRM</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  <nav class="bg-white shadow-md">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <h1 class="text-2xl font-bold text-purple-600">📱 WhatsApp AI CRM</h1>
      <div class="flex items-center gap-4">
        <span class="text-gray-600"><%= user.name %></span>
        <button onclick="logout()" class="px-4 py-2 text-red-600 hover:bg-red-50 rounded-lg transition">Sair</button>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-6 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h2 class="text-3xl font-bold text-gray-800 mb-2">Dashboard</h2>
      <p class="text-gray-600">Bem-vindo ao seu CRM. Gerencie seus clientes e mensagens.</p>
    </div>

    <!-- Sidebar + Main -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow p-4 space-y-2">
          <a href="/crm/dashboard" class="block w-full px-4 py-2 bg-purple-100 text-purple-700 rounded-lg font-semibold">📊 Dashboard</a>
          <a href="/crm/contacts" class="block w-full px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition">👥 Contatos</a>
          <a href="/crm/rules" class="block w-full px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition">🤖 Respostas</a>
        </div>
      </div>

      <!-- Main -->
      <div class="lg:col-span-4 space-y-6">
        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="bg-white rounded-lg shadow p-6">
            <div class="text-gray-500 text-sm font-semibold">Contatos</div>
            <div id="contactCount" class="text-3xl font-bold text-purple-600 mt-2">0</div>
          </div>
          <div class="bg-white rounded-lg shadow p-6">
            <div class="text-gray-500 text-sm font-semibold">Mensagens</div>
            <div id="messageCount" class="text-3xl font-bold text-blue-600 mt-2">0</div>
          </div>
          <div class="bg-white rounded-lg shadow p-6">
            <div class="text-gray-500 text-sm font-semibold">Regras Ativas</div>
            <div id="rulesCount" class="text-3xl font-bold text-green-600 mt-2">0</div>
          </div>
        </div>

        <!-- Recent Contacts -->
        <div class="bg-white rounded-lg shadow p-6">
          <h3 class="text-xl font-bold text-gray-800 mb-4">Contatos Recentes</h3>
          <div id="recentContacts" class="space-y-2">
            <p class="text-gray-500 text-center py-8">Carregando...</p>
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="bg-white rounded-lg shadow p-6">
          <h3 class="text-xl font-bold text-gray-800 mb-4">Ações Rápidas</h3>
          <a href="/crm/contacts" class="inline-block px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition">➕ Adicionar Contato</a>
          <a href="/crm/rules" class="inline-block px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition ml-2">⚙️ Criar Regra</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    const token = localStorage.getItem('token');

    async function loadDashboard() {
      try {
        // Load contacts
        const contactsRes = await fetch('/api/contacts', {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const contacts = await contactsRes.json();

        // Load messages
        const messagesRes = await fetch('/api/messages', {
          headers: { 'Authorization': `Bearer ${token}` }
        });

        // Load rules
        const rulesRes = await fetch('/api/rules', {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const rules = await rulesRes.json();

        // Update counts
        document.getElementById('contactCount').textContent = contacts.length;
        document.getElementById('rulesCount').textContent = rules.length;

        // Display recent contacts
        const recentContactsDiv = document.getElementById('recentContacts');
        if (contacts.length === 0) {
          recentContactsDiv.innerHTML = '<p class="text-gray-500 text-center py-8">Nenhum contato ainda</p>';
        } else {
          recentContactsDiv.innerHTML = contacts.slice(0, 5).map(c => `
            <a href="/crm/contacts/${c.id}" class="block p-4 border border-gray-200 rounded-lg hover:bg-purple-50 transition">
              <div class="font-semibold text-gray-800">${c.name || 'Sem nome'}</div>
              <div class="text-sm text-gray-500">${c.phone}</div>
            </a>
          `).join('');
        }
      } catch (err) {
        console.error('Erro ao carregar dashboard:', err);
      }
    }

    function logout() {
      localStorage.removeItem('token');
      window.location.href = '/login';
    }

    loadDashboard();
  </script>
</body>
</html>
