<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Respostas Automáticas - CRM</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  <nav class="bg-white shadow-md">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <h1 class="text-2xl font-bold text-purple-600">📱 WhatsApp AI CRM</h1>
      <div class="flex items-center gap-4">
        <span class="text-gray-600"><%= user.name %></span>
        <button onclick="logout()" class="px-4 py-2 text-red-600 hover:bg-red-50 rounded-lg transition">Sair</button>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-6 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow p-4 space-y-2">
          <a href="/crm/dashboard" class="block w-full px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition">📊 Dashboard</a>
          <a href="/crm/contacts" class="block w-full px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition">👥 Contatos</a>
          <a href="/crm/rules" class="block w-full px-4 py-2 bg-purple-100 text-purple-700 rounded-lg font-semibold">🤖 Respostas</a>
        </div>
      </div>

      <!-- Main Content -->
      <div class="lg:col-span-4">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-3xl font-bold text-gray-800">Respostas Automáticas</h2>
          <button onclick="openNewRuleModal()" class="px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition">➕ Nova Regra</button>
        </div>

        <!-- Info Box -->
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
          <p class="text-blue-800">
            <strong>💡 Dica:</strong> Configure palavras-chave para disparar respostas automáticas. 
            Quando um cliente enviar uma mensagem que corresponder ao gatilho, a resposta será enviada automaticamente.
          </p>
        </div>

        <!-- Rules List -->
        <div id="rulesList" class="space-y-4">
          <p class="text-gray-500 text-center py-8">Carregando...</p>
        </div>
      </div>
    </div>
  </div>

  <!-- New Rule Modal -->
  <div id="newRuleModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
    <div class="bg-white rounded-lg shadow-2xl max-w-md w-full p-6">
      <h3 class="text-2xl font-bold text-gray-800 mb-4">Nova Regra</h3>

      <form id="newRuleForm" class="space-y-4">
        <div>
          <label for="ruleTrigger" class="block text-sm font-medium text-gray-700 mb-2">Gatilho (palavra-chave)</label>
          <input type="text" id="ruleTrigger" name="trigger" required placeholder="ex: olá, oi, ?" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600">
          <p class="text-xs text-gray-500 mt-1">A mensagem deve conter esta palavra-chave exatamente</p>
        </div>

        <div>
          <label for="ruleResponse" class="block text-sm font-medium text-gray-700 mb-2">Resposta Automática</label>
          <textarea id="ruleResponse" name="response" required placeholder="Escreva a resposta que será enviada..." rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-600"></textarea>
        </div>

        <div class="flex gap-2 pt-4">
          <button type="submit" class="flex-1 px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition">Criar</button>
          <button type="button" onclick="closeNewRuleModal()" class="flex-1 px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition">Cancelar</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const token = localStorage.getItem('token');
    let allRules = [];

    async function loadRules() {
      try {
        const res = await fetch('/api/rules', {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        allRules = await res.json();
        renderRules(allRules);
      } catch (err) {
        console.error('Erro ao carregar regras:', err);
      }
    }

    function renderRules(rules) {
      const list = document.getElementById('rulesList');
      if (rules.length === 0) {
        list.innerHTML = '<p class="text-gray-500 text-center py-8">Nenhuma regra criada. Crie uma para começar!</p>';
      } else {
        list.innerHTML = rules.map(r => `
          <div class="bg-white rounded-lg shadow p-4">
            <div class="flex justify-between items-start">
              <div class="flex-1">
                <div class="font-semibold text-gray-800">Gatilho: <span class="text-purple-600 bg-purple-50 px-3 py-1 rounded">${r.trigger}</span></div>
                <div class="text-gray-600 mt-2">${r.response}</div>
                <div class="text-xs text-gray-500 mt-2">Criado: ${new Date(r.created_at).toLocaleDateString('pt-BR')}</div>
              </div>
              <button onclick="deleteRule('${r.id}')" class="px-3 py-1 text-red-600 hover:bg-red-50 rounded transition">🗑️</button>
            </div>
          </div>
        `).join('');
      }
    }

    function openNewRuleModal() {
      document.getElementById('newRuleModal').classList.remove('hidden');
    }

    function closeNewRuleModal() {
      document.getElementById('newRuleModal').classList.add('hidden');
    }

    document.getElementById('newRuleForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const trigger = document.getElementById('ruleTrigger').value;
      const response = document.getElementById('ruleResponse').value;

      try {
        const res = await fetch('/api/rules', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ trigger, response })
        });

        if (res.ok) {
          closeNewRuleModal();
          document.getElementById('newRuleForm').reset();
          loadRules();
        } else {
          const data = await res.json();
          alert('Erro: ' + data.error);
        }
      } catch (err) {
        alert('Erro ao criar regra: ' + err.message);
      }
    });

    async function deleteRule(ruleId) {
      if (!confirm('Tem certeza que deseja deletar esta regra?')) return;

      try {
        const res = await fetch(`/api/rules/${ruleId}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` }
        });

        if (res.ok) {
          loadRules();
        } else {
          alert('Erro ao deletar regra');
        }
      } catch (err) {
        alert('Erro ao deletar regra: ' + err.message);
      }
    }

    function logout() {
      localStorage.removeItem('token');
      window.location.href = '/login';
    }

    loadRules();
  </script>
</body>
</html>
