<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 - Página não encontrada</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-purple-600 to-purple-900 min-h-screen flex items-center justify-center">
  <div class="text-center">
    <h1 class="text-6xl font-bold text-white mb-4">404</h1>
    <p class="text-2xl text-purple-200 mb-8">Página não encontrada</p>
    <p class="text-purple-100 mb-8">O caminho <%= path %> não existe.</p>
    <a href="/" class="inline-block px-8 py-3 bg-white text-purple-600 font-semibold rounded-lg hover:bg-purple-50 transition">
      ← Voltar para início
    </a>
  </div>
</body>
</html>
