<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gerenciar Tenants - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <!-- Navigation -->
  <nav class="bg-gray-800 shadow-md">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <h1 class="text-2xl font-bold text-white">🛡️ Admin Panel</h1>
      <div class="flex items-center gap-4">
        <span class="text-gray-300">Admin</span>
        <button onclick="logout()" class="px-4 py-2 text-red-400 hover:bg-red-600 hover:text-white rounded-lg transition">Sair</button>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-6 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow p-4 space-y-2">
          <a href="/admin/dashboard" class="block w-full px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg transition">📊 Dashboard</a>
          <a href="/admin/tenants" class="block w-full px-4 py-2 bg-gray-800 text-white rounded-lg font-semibold">👥 Tenants</a>
        </div>
      </div>

      <!-- Main Content -->
      <div class="lg:col-span-4">
        <div class="mb-6">
          <h2 class="text-3xl font-bold text-gray-800">Gerenciar Tenants</h2>
        </div>

        <!-- Filters -->
        <div class="mb-6 flex gap-2">
          <input type="text" id="searchInput" placeholder="Buscar por nome ou email..." class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-600">
          <select id="statusFilter" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-600">
            <option value="">Todos os status</option>
            <option value="active">Ativo</option>
            <option value="suspended">Suspenso</option>
          </select>
        </div>

        <!-- Tenants Table -->
        <div class="bg-white rounded-lg shadow overflow-hidden">
          <table class="w-full">
            <thead class="bg-gray-100 border-b">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700">Nome</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700">Email</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700">Plano</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700">Status</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700">Contatos</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700">Mensagens</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700">Ações</th>
              </tr>
            </thead>
            <tbody id="tenantsList">
              <tr>
                <td colspan="7" class="px-6 py-8 text-center text-gray-500">Carregando...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Tenant Modal -->
  <div id="editTenantModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
    <div class="bg-white rounded-lg shadow-2xl max-w-md w-full p-6">
      <h3 class="text-2xl font-bold text-gray-800 mb-4">Editar Tenant</h3>

      <form id="editTenantForm" class="space-y-4">
        <div>
          <label for="editStatus" class="block text-sm font-medium text-gray-700 mb-2">Status</label>
          <select id="editStatus" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-600">
            <option value="active">Ativo</option>
            <option value="suspended">Suspenso</option>
          </select>
        </div>

        <div>
          <label for="editPlan" class="block text-sm font-medium text-gray-700 mb-2">Plano</label>
          <select id="editPlan" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-600">
            <option value="free">Free</option>
            <option value="pro">Pro</option>
            <option value="premium">Premium</option>
          </select>
        </div>

        <div class="flex gap-2 pt-4">
          <button type="submit" class="flex-1 px-4 py-2 bg-gray-800 text-white rounded-lg hover:bg-gray-900 transition">Salvar</button>
          <button type="button" onclick="closeEditTenantModal()" class="flex-1 px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition">Cancelar</button>
        </div>
      </form>

      <hr class="my-4">

      <button onclick="deleteTenant()" class="w-full px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">🗑️ Deletar Tenant</button>
    </div>
  </div>

  <script>
    const adminToken = localStorage.getItem('adminToken');
    let allTenants = [];
    let currentEditTenantId = null;

    if (!adminToken) {
      window.location.href = '/admin/login';
    }

    async function loadTenants() {
      try {
        const res = await fetch('/admin/api/tenants', {
          headers: { 'X-Admin-Token': adminToken }
        });
        allTenants = await res.json();
        renderTenants(allTenants);
      } catch (err) {
        console.error('Erro ao carregar tenants:', err);
      }
    }

    function renderTenants(tenants) {
      const list = document.getElementById('tenantsList');
      if (tenants.length === 0) {
        list.innerHTML = '<tr><td colspan="7" class="px-6 py-8 text-center text-gray-500">Nenhum tenant</td></tr>';
      } else {
        list.innerHTML = tenants.map(t => `
          <tr class="border-b hover:bg-gray-50">
            <td class="px-6 py-4 text-sm font-semibold text-gray-800">${t.name}</td>
            <td class="px-6 py-4 text-sm text-gray-600">${t.email}</td>
            <td class="px-6 py-4 text-sm"><span class="px-2 py-1 rounded text-xs font-semibold bg-blue-100 text-blue-800">${t.plan}</span></td>
            <td class="px-6 py-4 text-sm">
              <span class="px-2 py-1 rounded text-xs font-semibold ${t.status === 'active' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">
                ${t.status}
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-600">${t.contact_count || 0}</td>
            <td class="px-6 py-4 text-sm text-gray-600">${t.message_count || 0}</td>
            <td class="px-6 py-4 text-sm">
              <button onclick="openEditTenantModal('${t.id}', '${t.status}', '${t.plan}')" class="text-blue-600 hover:text-blue-800 font-semibold">✏️ Editar</button>
            </td>
          </tr>
        `).join('');
      }
    }

    function openEditTenantModal(tenantId, status, plan) {
      currentEditTenantId = tenantId;
      document.getElementById('editStatus').value = status;
      document.getElementById('editPlan').value = plan;
      document.getElementById('editTenantModal').classList.remove('hidden');
    }

    function closeEditTenantModal() {
      document.getElementById('editTenantModal').classList.add('hidden');
      currentEditTenantId = null;
    }

    document.getElementById('editTenantForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const status = document.getElementById('editStatus').value;
      const plan = document.getElementById('editPlan').value;

      try {
        const res = await fetch(`/admin/api/tenants/${currentEditTenantId}`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'X-Admin-Token': adminToken
          },
          body: JSON.stringify({ status, plan })
        });

        if (res.ok) {
          closeEditTenantModal();
          loadTenants();
        } else {
          alert('Erro ao atualizar tenant');
        }
      } catch (err) {
        alert('Erro: ' + err.message);
      }
    });

    async function deleteTenant() {
      if (!confirm('Tem certeza? Esta ação é irreversível!')) return;

      try {
        const res = await fetch(`/admin/api/tenants/${currentEditTenantId}`, {
          method: 'DELETE',
          headers: { 'X-Admin-Token': adminToken }
        });

        if (res.ok) {
          closeEditTenantModal();
          loadTenants();
        } else {
          alert('Erro ao deletar tenant');
        }
      } catch (err) {
        alert('Erro: ' + err.message);
      }
    }

    document.getElementById('searchInput').addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      const filtered = allTenants.filter(t =>
        t.name.toLowerCase().includes(query) ||
        t.email.toLowerCase().includes(query)
      );
      renderTenants(filtered);
    });

    document.getElementById('statusFilter').addEventListener('change', (e) => {
      const status = e.target.value;
      const filtered = status ? allTenants.filter(t => t.status === status) : allTenants;
      renderTenants(filtered);
    });

    function logout() {
      localStorage.removeItem('adminToken');
      window.location.href = '/admin/login';
    }

    loadTenants();
  </script>
</body>
</html>
