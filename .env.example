# WhatsApp AI CRM - Configuração de Ambiente

# Servidor
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Banco de dados
DB_TYPE=sqlite
DB_PATH=./data/crm.db
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/crm_saas

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# Sessão
SESSION_SECRET=your_super_secret_session_key

# WhatsApp
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=./data/whatsapp_session
WHATSAPP_TIMEOUT=60000

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_SECRET=admin_panel_secret_key

# Feature Flags
ENABLE_AI_RESPONSES=false
ENABLE_WEBHOOKS=false
